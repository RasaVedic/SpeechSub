<?xml version="1.0" encoding="utf-8"?>
<!--
    Data Extraction Rules — controls what data Android can back up via Auto Backup.
    We exclude the Room database from cloud backup to protect user privacy.
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude local database and shared preferences from cloud -->
        <exclude domain="database" />
        <exclude domain="sharedpref" />
    </cloud-backup>
    <device-transfer>
        <!-- Allow device-to-device transfer of shared prefs (settings) -->
        <exclude domain="database" />
    </device-transfer>
</data-extraction-rules>
